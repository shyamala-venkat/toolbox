# ToolBox — Environment Variables for Code Signing
# Copy this file to `.env` and fill in your values.
# See SIGNING.md for setup instructions.

# ── Tauri Updater Signing ──────────────────────────────────────────────
# Generate with: npx tauri signer generate -w ~/.tauri/toolbox.key
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# ── macOS Code Signing ─────────────────────────────────────────────────
# Requires Apple Developer Program ($99/yr)
APPLE_CERTIFICATE=
APPLE_CERTIFICATE_PASSWORD=
APPLE_SIGNING_IDENTITY=

# ── macOS Notarization ─────────────────────────────────────────────────
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
